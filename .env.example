# Copy this file to `.env` and fill in your Kimi (Moonshot) API key.
# Get a key from https://platform.moonshot.cn (or ask the project lead).

# Moonshot uses an OpenAI-compatible endpoint, so we set both flavors of the
# env var so anything that reads either OPENAI_API_KEY or MOONSHOT_API_KEY
# picks up the same key.
OPENAI_API_KEY=your_kimi_key_here
OPENAI_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_API_KEY=your_kimi_key_here

# Default model names (do not change unless you have a reason)
KIMI_MODEL_LONG=moonshot-v1-128k
KIMI_MODEL_MID=moonshot-v1-32k
KIMI_MODEL_SHORT=moonshot-v1-8k
