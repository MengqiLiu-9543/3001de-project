# Copy this file to `.env` and fill in your own Kimi API key.
#
# 1. Sign up at https://platform.moonshot.cn
# 2. Generate an API key in the dashboard
# 3. Replace `your_kimi_key_here` below with that key
#
# Kimi exposes an OpenAI-compatible HTTP API, so we set both OPENAI_*
# and MOONSHOT_* variables to the same key/URL — different parts of the
# pipeline (DocETL via LiteLLM, DataGatherer's own client) read different
# names.

OPENAI_API_KEY=your_kimi_key_here
OPENAI_BASE_URL=https://api.moonshot.cn/v1

MOONSHOT_API_KEY=your_kimi_key_here
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
